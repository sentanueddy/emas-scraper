# ID spreadsheet (ambil dari URL Google Sheet, bagian antara /d/ dan /edit)
SPREADSHEET_ID=ganti_dengan_id_spreadsheet_anda

# Nama tab/sheet tujuan (buat dulu tab dengan nama ini)
SHEET_NAME=Harga Emas

# Jadwal cron (default: tiap jam). Format: menit jam tgl bln hari
# Contoh: "0 9 * * *" = tiap hari jam 09:00 WIB
CRON_SCHEDULE=0 * * * *

# Zona waktu
TZ=Asia/Jakarta
